PORT=5000
NODE_ENV=production

# URL publica de la web, por ejemplo: https://bravasmarketing.com
SITE_URL=https://tu-dominio.com
FRONTEND_URL=https://tu-dominio.com
CORS_ORIGINS=https://tu-dominio.com

# Gmail requiere una App Password, no la contraseña normal de la cuenta.
EMAIL_USER=tu-cuenta@gmail.com
EMAIL_PASS=tu-app-password
EMAIL_DESTINO=hola@tu-dominio.com

# Maximo de envios por IP cada 15 minutos.
RATE_LIMIT_MAX_REQUESTS=5
